# ── SERVEUR ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── BASE DE DONNÉES ───────────────────────────────────
DB_PATH=./db/clothesparis.db

# ── SÉCURITÉ ──────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=7d

# ── STRIPE (paiement) ─────────────────────────────────
# Récupérer sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLIC_KEY=pk_test_...

# ── EMAILS (nodemailer) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton_email@gmail.com
SMTP_PASS=ton_app_password_gmail
EMAIL_FROM=ClothesParis <contact@clothesparis.fr>

# ── FRONTEND ──────────────────────────────────────────
FRONTEND_URL=http://localhost:8080
